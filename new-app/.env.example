# Example environment variables for local dev
# Copy this file to `.env` and set your key if you want AI-generated snippets.
# Warning: Putting API keys in frontend envs is convenient for local dev but not secure for production.

VITE_OPENAI_KEY=
VITE_STORY_PROXY_URL=

